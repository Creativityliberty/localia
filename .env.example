# =====================================
# Localia — variables d'environnement
# =====================================

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="Localia"

# InsForge — backend (Postgres + Auth + Storage)
# Crée un projet sur https://insforge.dev
NEXT_PUBLIC_INSFORGE_URL="https://your-appp.insforge.app/"
NEXT_PUBLIC_INSFORGE_ANON_KEY="your-anon-key"
INSFORGE_API_KEY="youur-api-key"

# Auth
AUTH_SECRET="CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"

# IA — générateur mini-site (optionnel)
# Récupère sur https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Brevo — relances email (optionnel, P1)
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="hello@localia.app"
BREVO_SENDER_NAME="Localia"

# Storage bucket InsForge
INSFORGE_STORAGE_BUCKET="localia-media"
